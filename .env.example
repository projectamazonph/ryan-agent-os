# Shared
RAOS_ENV=development
RAOS_LOG_LEVEL=INFO
RAOS_OWNER_EMAIL=ryan.d@goodwitcommerce.com
RAOS_OWNER_PASSWORD=change-me-now
RAOS_JWT_SECRET=replace-with-at-least-32-random-characters
RAOS_JWT_TTL_MINUTES=720

# API
RAOS_API_HOST=0.0.0.0
RAOS_API_PORT=8000
RAOS_DATABASE_URL=postgresql+asyncpg://raos:raos@postgres:5432/raos
RAOS_REDIS_URL=redis://redis:6379/0
RAOS_AUTO_CREATE_TABLES=true
RAOS_AUTO_PROCESS_CAPTURES=true
RAOS_CORS_ORIGINS=http://localhost:3000

# Model routing
# rules = deterministic offline baseline
# hermes = local OpenAI-compatible endpoint
# cloud = hosted OpenAI-compatible endpoint and requires RAOS_MODEL_API_KEY
RAOS_MODEL_PROVIDER=rules
RAOS_MODEL_BASE_URL=http://host.docker.internal:8080/v1
RAOS_MODEL_NAME=hermes-3
RAOS_MODEL_API_KEY=
RAOS_MODEL_TIMEOUT_SECONDS=60
RAOS_MAX_UPLOAD_BYTES=26214400

# Object storage
RAOS_S3_ENDPOINT=http://minio:9000
RAOS_S3_ACCESS_KEY=raos
RAOS_S3_SECRET_KEY=raos-local-secret
RAOS_S3_BUCKET=raos-local
RAOS_S3_REGION=us-east-1
RAOS_S3_SECURE=false

# Web
API_INTERNAL_URL=http://api:8000
NEXT_PUBLIC_APP_NAME=Ryan Agent OS
COOKIE_SECURE=false
